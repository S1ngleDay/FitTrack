{
  "cli": {
    "version": ">= 3.8.2"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "backgroundModes": ["location"]
      },
      "ios": {
        "backgroundModes": ["background-fetch", "background-processing"]
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "backgroundModes": ["location"]
      },
      "ios": {
        "backgroundModes": ["background-fetch", "background-processing"]
      }
    },
    "production": {
      "android": {
        "backgroundModes": ["location"]
      },
      "ios": {
        "backgroundModes": ["background-fetch", "background-processing"]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
